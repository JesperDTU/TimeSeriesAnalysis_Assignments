    "# Investigate the residuals of the model. Are the model assumptions fulfilled?\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy import stats\n",
    "\n",
    "resid = np.asarray(residuals)\n",
    "fitted = np.asarray(y_hat)\n",
